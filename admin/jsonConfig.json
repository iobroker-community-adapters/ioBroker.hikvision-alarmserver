{
    "type": "tabs",
    "i18n": true,
    "tabsStyle": {"width": "calc(100% - 100px)"},
    "items": {
        "mainTab": {
            "type": "panel",
            "label": "mainSettings",
            "items": {
                "port": {
                    "type": "number",
                    "min": 1,
                    "max": 65565,
                    "label": "listenPort",
                    "xs": 12,
                    "sm": 6,
                    "md": 4,
                    "lg": 3,
                    "xl": 3
                },
                "bind": {
                    "type": "ip",
                    "label": "listenAddress",
                    "xs": 12,
                    "sm": 6,
                    "md": 4,
                    "lg": 3,
                    "xl": 3
                },
                "alarmTimeout": {
                    "type": "number",
                    "newLine": true,
                    "min": 0,
                    "label": "alarmTimeout",
                    "help": "alarmTimeoutHelp",
                    "xs": 12,
                    "sm": 12,
                    "md": 6,
                    "lg": 4,
                    "xl": 4
                }
            }
        },
        "channelsTab": {
            "type": "panel",
            "label": "channels",
            "items": {
                "useChannels": {
                    "type": "checkbox",
                    "label": "useChannels",
                    "help": "useChannelsHelp",
                    "xs": 12,
                    "sm": 12,
                    "md": 12,
                    "lg": 12,
                    "xl": 12
                },
                "useDetectionTargets": {
                    "type": "checkbox",
                    "label": "useDetectionTargets",
                    "help": "useDetectionTargetsHelp",
                    "xs": 12,
                    "sm": 12,
                    "md": 12,
                    "lg": 12,
                    "xl": 12
                }
            }
        },
        "sendTab": {
            "type": "panel",
            "label": "sending",
            "items": {
                "_description": {
                    "type": "staticText",
                    "text": "sendingDescription",
                    "format": "html"
                },
                "_xmlHead": {
                    "type": "header",
                    "size": 2,
                    "text": "xmlEventParts"
                },
                "sendXmlInstance": {
                    "newLine": true,
                    "type": "instance",
                    "label": "sendXmlInstance",
                    "xs": 12,
                    "sm": 12,
                    "md": 6,
                    "lg": 4,
                    "xl": 4
                },
                "sendXmlCommand": {
                    "newLine": true,
                    "type": "text",
                    "label": "sendXmlCommand",
                    "xs": 12,
                    "sm": 12,
                    "md": 6,
                    "lg": 4,
                    "xl": 4,
                    "hidden": "data.sendXmlInstance == ''"
                },
                "sendXmlMessage": {
                    "type": "text",
                    "trim": false,
                    "label": "sendXmlMessage",
                    "help": "sendXmlMessageHelp",
                    "xs": 12,
                    "sm": 12,
                    "md": 12,
                    "lg": 12,
                    "xl": 12,
                    "hidden": "data.sendXmlInstance == ''",
                    "validator": "data.sendXmlInstance == '' || data.sendXmlMessage != ''",
                    "validatorErrorText": "sendXmlMessageRequired",
                    "validatorNoSaveOnError": true
                },
                "sendXmlThrottle": {
                    "type": "number",
                    "min": 0,
                    "label": "sendXmlThrottle",
                    "help": "sendThrottleHelp",
                    "xs": 12,
                    "sm": 12,
                    "md": 6,
                    "lg": 4,
                    "xl": 4,
                    "hidden": "data.sendXmlInstance == ''"
                },
                "sendXmlThrottleByDevice": {
                    "type": "checkbox",
                    "label": "sendXmlThrottleByDevice",
                    "help": "sendThrottleByDeviceHelp",
                    "xs": 12,
                    "sm": 12,
                    "md": 12,
                    "lg": 12,
                    "xl": 12,
                    "hidden": "data.sendXmlInstance == ''"
                },
                "_imageHead": {
                    "type": "header",
                    "size": 2,
                    "text": "imageEventParts"
                },
                "sendImageInstance": {
                    "newLine": true,
                    "type": "instance",
                    "label": "sendImageInstance",
                    "xs": 12,
                    "sm": 12,
                    "md": 6,
                    "lg": 4,
                    "xl": 4
                },
                "sendImageCommand": {
                    "newLine": true,
                    "type": "text",
                    "label": "sendImageCommand",
                    "xs": 12,
                    "sm": 12,
                    "md": 6,
                    "lg": 4,
                    "xl": 4,
                    "hidden": "data.sendImageInstance == ''"
                },
                "sendImageMessage": {
                    "type": "text",
                    "trim": false,
                    "label": "sendImageMessage",
                    "help": "sendImageMessageHelp",
                    "xs": 12,
                    "sm": 12,
                    "md": 12,
                    "lg": 12,
                    "xl": 12,
                    "hidden": "data.sendImageInstance == ''",
                    "validator": "data.sendImageInstance == '' || data.sendImageMessage != ''",
                    "validatorErrorText": "sendImageMessageRequired",
                    "validatorNoSaveOnError": true
                },
                "sendImageThrottle": {
                    "type": "number",
                    "min": 0,
                    "label": "sendImageThrottle",
                    "help": "sendThrottleHelp",
                    "xs": 12,
                    "sm": 12,
                    "md": 6,
                    "lg": 4,
                    "xl": 4,
                    "hidden": "data.sendImageInstance == ''"
                },
                "sendImageThrottleByDevice": {
                    "type": "checkbox",
                    "label": "sendImageThrottleByDevice",
                    "help": "sendThrottleByDeviceHelp",
                    "xs": 12,
                    "sm": 12,
                    "md": 12,
                    "lg": 12,
                    "xl": 12,
                    "hidden": "data.sendImageInstance == ''"
                }
            }
        },
        "saveTab": {
            "type": "panel",
            "label": "saving",
            "items": {
                "_description": {
                    "type": "staticText",
                    "text": "savingDescription"
                },
                "saveXml": {
                    "type": "checkbox",
                    "label": "saveXml",
                    "xs": 12,
                    "sm": 12,
                    "md": 12,
                    "lg": 12,
                    "xl": 12
                },
                "saveImages": {
                    "type": "checkbox",
                    "label": "saveImages",
                    "xs": 12,
                    "sm": 12,
                    "md": 12,
                    "lg": 12,
                    "xl": 12
                }
            }
        },
        "processingTab": {
            "type": "panel",
            "label": "processing",
            "items": {
                "_description": {
                    "type": "staticText",
                    "text": "processingDescription"
                },
                "annotateImages": {
                    "type": "checkbox",
                    "label": "annotateImages",
                    "help": "annotateImagesHelp",
                    "xs": 12,
                    "sm": 12,
                    "md": 12,
                    "lg": 12,
                    "xl": 12
                }
            }
        }
    }
}
