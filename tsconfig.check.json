// Specialized tsconfig for type-checking js files
{
    "extends": "./tsconfig.json",
    "compilerOptions": {
        "skipLibCheck": true,
        "types": ["node", "mocha"]
    },
    "include": [
        "**/*.js",
        "**/*.d.ts"
    ],
    "exclude": [
        "**/build",
        "node_modules/",
        "widgets/",
        "gulpfile.js"
    ]
}
